# dLogos environment — copy to .env and fill in. Every var has a safe default
# in src/dlogos/config.py, so the OFFLINE unit-test suite runs with no .env at
# all. The values below are what the ONE-EPISODE SMOKE RUN
# (scripts/smoke_one_episode.py, docs/RUNBOOK.md step 1) needs to talk to real,
# lowest-friction hosted infra: AssemblyAI (ASR) + DeepInfra (extraction +
# embeddings) + local Neo4j (docker compose). No GPU required.

# --- ASR: hosted AssemblyAI (lowest-friction smoke path; diarization + word
#     timestamps, no GPU). One key buys speaker_labels + utterances over HTTPS.
#     Get a key at https://www.assemblyai.com/ (REQUIRED for the smoke). ---
ASSEMBLYAI_API_KEY=

# --- Open-weight extraction endpoint (OpenAI-compatible). For the smoke, point
#     this at DeepInfra and use an open-weight model. REQUIRED for the smoke. ---
EXTRACTION_BASE_URL=https://api.deepinfra.com/v1/openai
EXTRACTION_API_KEY=
EXTRACTION_MODEL=deepseek-ai/DeepSeek-V3

# --- Open embedding endpoint (OpenAI-compatible; BGE-M3 via DeepInfra). The
#     same DeepInfra key works for both extraction and embeddings. REQUIRED. ---
EMBED_BASE_URL=https://api.deepinfra.com/v1/openai
EMBED_API_KEY=
EMBED_MODEL=BAAI/bge-m3

# --- Neo4j graph backend (local, via `docker compose up -d neo4j`). The direct
#     Neo4jStore (graph/neo4j_store.py) speaks Bolt with these creds. REQUIRED. ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dlogos-dev-password
# Used by docker-compose (must match NEO4J_USER/NEO4J_PASSWORD):
NEO4J_AUTH=neo4j/dlogos-dev-password

# --- Frontier model for the OPTIONAL head-to-head side-by-side in the smoke
#     (model-alone arm vs the dLogos arm) and the four-arm eval. Set all three
#     to enable the smoke's --frontier preview; leave blank to skip it. ---
FRONTIER_BASE_URL=https://api.anthropic.com/v1
FRONTIER_API_KEY=
FRONTIER_MODEL=claude-opus-4-8
# Web-search-enabled arm (eval arm 2) may use a separate endpoint/key if needed:
FRONTIER_WEB_SEARCH_BASE_URL=
FRONTIER_WEB_SEARCH_API_KEY=
FRONTIER_WEB_SEARCH_MODEL=

# --- Podcast Index (ingestion: feed resolution + episode GUIDs). Only needed
#     when the smoke is driven from an RSS feed URL + episode index; not needed
#     for the --audio-url path. ---
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# --- Resolution: Wikidata SPARQL endpoint (recurring-guest canonicalization).
#     Not exercised by the one-episode smoke; used from step 2 onward. ---
WIKIDATA_ENDPOINT=https://query.wikidata.org/sparql

# --- ASR: HuggingFace token for the gated pyannote diarization pipeline. Only
#     for the self-hosted WhisperX path, NOT the hosted AssemblyAI smoke. ---
HF_TOKEN=
