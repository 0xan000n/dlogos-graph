# --- Podcast Index (ingestion: feed resolution + episode GUIDs) ---
PODCAST_INDEX_KEY=
PODCAST_INDEX_SECRET=

# --- Open-weight extraction endpoint (OpenAI-compatible) ---
EXTRACTION_BASE_URL=http://localhost:8000/v1
EXTRACTION_API_KEY=sk-no-key-required
EXTRACTION_MODEL=deepseek-v3

# --- Open embedding endpoint (OpenAI-compatible; e.g. BGE-M3 served via vLLM/TEI) ---
EMBED_BASE_URL=http://localhost:8001/v1
EMBED_API_KEY=sk-no-key-required
EMBED_MODEL=bge-m3

# --- Neo4j / Graphiti graph backend ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dlogos-dev-password
# Used by docker-compose (must match NEO4J_USER/NEO4J_PASSWORD):
NEO4J_AUTH=neo4j/dlogos-dev-password

# --- Frontier model for the head-to-head eval (the strong baseline; both sides) ---
FRONTIER_BASE_URL=https://api.anthropic.com/v1
FRONTIER_API_KEY=
FRONTIER_MODEL=claude-opus-4-8
# Web-search-enabled arm (arm 2) may use a separate endpoint/key if needed:
FRONTIER_WEB_SEARCH_BASE_URL=
FRONTIER_WEB_SEARCH_API_KEY=
FRONTIER_WEB_SEARCH_MODEL=

# --- Resolution: Wikidata SPARQL endpoint (recurring-guest canonicalization) ---
WIKIDATA_ENDPOINT=https://query.wikidata.org/sparql
